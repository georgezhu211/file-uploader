<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Folders</title>
  </head>
  <body>
    <h1>Folders</h1>
    <ul>
      <% for (const folder of folders) { %>
        <li>
          <%= folder.name %>
          <a href="/folders/<%= folder.id %>">View</a>
          <a href="/folders/<%= folder.id %>/edit">Edit</a>
        </li>
      <% } %>
    </ul>
  </body>
</html>
