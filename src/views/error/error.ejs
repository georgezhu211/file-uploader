<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= status %> - <%= title %></title>
    <link rel="stylesheet" href="https://unpkg.com/xp.css@0.2.6/dist/XP.css" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="desktop">
      <div class="window" style="max-width: 420px; margin: 80px auto">
        <div class="title-bar">
          <div class="title-bar-text">Error</div>
          <div class="title-bar-controls">
            <button aria-label="Close"></button>
          </div>
        </div>
        <div class="window-body" style="padding: 16px">
          <div style="display: flex; align-items: flex-start; gap: 16px">
            <img
              src="https://win98icons.alexmeub.com/icons/png/msg_error-0.png"
              alt="Error"
              style="width: 32px; height: 32px; flex-shrink: 0; margin-top: 2px"
            />
            <div>
              <p style="margin: 0 0 8px 0">
                <strong><%= status %> - <%= title %></strong>
              </p>
              <p style="margin: 0"><%= message %></p>
            </div>
          </div>
          <div style="text-align: center; margin-top: 20px">
            <a href="/">
              <button style="min-width: 75px">OK</button>
            </a>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
