<nav aria-label="Breadcrumb">
  <a href="/folders">My Drive</a> &gt;
  <a href="/folders/<%= file.folder.id %>"><%= file.folder.name %></a> &gt;
  <span><%= file.name %></span>
</nav>
<%- include('../partials/errors') %>
<h1><%= file.name %></h1>
<p>Type: <%= file.mimetype %></p>
<p>Size: <%= formatSize(file.size) %></p>
<p>Uploaded: <%= new Date(file.createdAt).toLocaleString() %></p>
<a href="/files/<%= file.id %>/download"><button>Download</button></a>
<form
  action="/files/<%= file.id %>?_method=DELETE"
  method="POST"
  onsubmit="return confirm('Are you sure you want to delete this file?');"
>
  <button type="submit">Delete</button>
</form>
