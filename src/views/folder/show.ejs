<div class="toolbar">
  <button onclick="location.href = '/folders'">⬆ Up</button>
  <button onclick="location.href = '/folders/<%= folder.id %>/edit'">
    ✏️ Rename
  </button>
  <button
    onclick="
      if (confirm('Delete this folder and all its files?'))
        document.getElementById('delete-folder-form').submit();
    "
  >
    🗑️ Delete
  </button>
</div>

<div class="address-bar">
  <a href="/folders">My Drive</a>
  <span>&rsaquo;</span>
  <span><%= folder.name %></span>
</div>

<%- include("../partials/errors") %>

<!-- Files Section -->
<%- include("_files") %>

<hr />

<!-- Shares Section -->
<%- include("_shares") %>

<form
  id="delete-folder-form"
  action="/folders/<%= folder.id %>?_method=DELETE"
  method="POST"
  style="display: none"
></form>
