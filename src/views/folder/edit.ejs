<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rename folder</title>
  </head>
  <body>
    <h1>Rename folder</h1>
    <form action="/folders/<%= folder.id %>?_method=PUT" method="POST">
      <input type="text" name="name" id="name" value="<%= folder.name %>" />
      <button type="submit">Rename</button>
    </form>
  </body>
</html>
