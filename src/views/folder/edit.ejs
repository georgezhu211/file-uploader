<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rename folder</title>
  </head>
  <body>
    <h1>Rename folder</h1>
    <%- include("../partials/errors") %>
    <form action="/folders/<%= folder.id %>?_method=PUT" method="POST">
      <input
        type="text"
        name="name"
        id="name"
        value="<%= locals.input?.name || folder.name %>"
      />
      <button type="submit">Rename</button>
    </form>
  </body>
</html>
