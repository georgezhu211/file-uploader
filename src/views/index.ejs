<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Home</title>
  </head>
  <body>
    <% if (user) {%>
      <span>Welcome back, @<%= locals.user.username %>!</span>
      <a href="/auth/logout">Log out</a>
    <% } else { %>
      <a href="/auth/signup">Sign up</a>
      <a href="/auth/login">Log in</a>
    <% } %>
  </body>
</html>
