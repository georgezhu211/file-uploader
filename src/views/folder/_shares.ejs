<fieldset>
  <legend>Share Folder</legend>
  <% if (folder.shares.length > 0) { %>
    <p style="font-size: 11px; margin: 0 0 4px;">Active share links:</p>
    <ul class="share-list">
      <% for (const share of folder.shares) { %>
        <li>
          <code><%= share.token.substring(0, 8) %>...</code>
          <span>expires <%= share.expiresAt.toLocaleDateString() %></span>
          <div class="inline-actions">
            <button type="button" onclick="navigator.clipboard.writeText(location.origin + '/share/<%= share.token %>')">📋 Copy</button>
            <form action="/folders/<%= folder.id %>/share/<%= share.token %>?_method=DELETE" method="POST" class="inline-form">
              <button type="submit" onclick="return confirm('Delete this share link?')">🗑️</button>
            </form>
          </div>
        </li>
      <% } %>
    </ul>
  <% } %>

  <form action="/folders/<%= folder.id %>/share" method="POST">
    <div class="form-row">
      <label for="duration">Expires in</label>
      <input id="duration" name="duration" type="number" min="1" max="30" value="7" style="width: 50px" required />
      <span>days</span>
      <button type="submit">Generate Link</button>
    </div>
  </form>
</fieldset>
